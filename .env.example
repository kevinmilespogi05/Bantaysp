# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# ─── Supabase ────────────────────────────────────────────────────────────────
# Frontend keys (with VITE_ prefix for client-side access)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_SERVICE_KEY=your_service_key_here

# Backend keys (without VITE_ prefix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Cloudinary (Image Uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── SendGrid (Email) ────────────────────────────────────────────────────────
# Get your key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_api_key_here

# ─── Brevo/Sendinblue (Legacy - Deprecated) ─────────────────────────────────
# BREVO_API_KEY=your_brevo_key_here

# ─── Server Configuration ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
